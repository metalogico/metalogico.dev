---
// Michele Brandolin - Personal Homepage
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<!-- Google tag (gtag.js) -->
		<script
			is:inline
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-K67NXFTFPG"
		></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-K67NXFTFPG");
		</script>
		<link rel="icon" type="image/svg" href="/favicon.svg" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>
			Michele Brandolin - Software Architect & Full Stack Developer
		</title>
		<meta
			name="description"
			content="Software Architect and Full Stack Developer with 25 years of experience. Specialized in Laravel, PHP, and modern web development."
		/>
		<meta name="generator" content={Astro.generator} />
		<script src="https://unpkg.com/lucide@latest"></script>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body class="bg-gray-900 text-white overflow-x-hidden">

		<!-- Navigation -->
		<nav
			class="fixed top-0 w-full z-50 bg-gray-900/95 border-b border-gray-800/50"
		>
			<div class="max-w-3xl mx-auto px-6 py-4">
				<div class="flex justify-between items-center">
					<a href="#" class="text-lg font-mono font-medium text-violet-400">
						metalogico
					</a>
					<div class="hidden md:flex gap-6">
						<a
							href="#about"
							class="text-sm text-gray-400 hover:text-violet-400 transition-colors"
							>About</a
						>
						<a
							href="#experience"
							class="text-sm text-gray-400 hover:text-violet-400 transition-colors"
							>Experience</a
						>
						<a
							href="#projects"
							class="text-sm text-gray-400 hover:text-violet-400 transition-colors"
							>Projects</a
						>
						<a
							href="#contact"
							class="text-sm text-gray-400 hover:text-violet-400 transition-colors"
							>Contact</a
						>
					</div>
					<button
						id="mobile-menu-toggle"
						class="md:hidden text-white"
					>
						<i data-lucide="menu" class="w-5 h-5"></i>
					</button>
				</div>
				<!-- Mobile Menu -->
				<div
					id="mobile-menu"
					class="hidden md:hidden mt-4 pb-4 space-y-3"
				>
					<a
						href="#about"
						class="block text-sm text-gray-400 hover:text-violet-400 transition-colors"
						>About</a
					>
					<a
						href="#experience"
						class="block text-sm text-gray-400 hover:text-violet-400 transition-colors"
						>Experience</a
					>
					<a
						href="#projects"
						class="block text-sm text-gray-400 hover:text-violet-400 transition-colors"
						>Projects</a
					>
					<a
						href="#contact"
						class="block text-sm text-gray-400 hover:text-violet-400 transition-colors"
						>Contact</a
					>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="min-h-screen flex items-center dot-grid">
			<div class="max-w-3xl mx-auto px-6 py-20">
				<div class="flex flex-col-reverse lg:flex-row gap-12 items-center lg:items-start">
					<!-- Text Content -->
					<div class="space-y-6 text-center lg:text-left flex-1">
						<div class="space-y-3">
							<h1 class="text-4xl lg:text-5xl font-bold leading-tight tracking-tight">
								Michele<br />
								<span class="gradient-text">Brandolin</span>
							</h1>
							<p class="text-lg text-gray-400 font-light">
								Software Architect & Full Stack Developer
							</p>
							<p class="text-base text-gray-500 max-w-md">
								25 years of experience in web development.
								Specialized in Laravel, scalable architectures
								and innovative solutions.
							</p>
						</div>

						<div
							class="flex flex-wrap gap-3 justify-center lg:justify-start"
						>
							<a
								href="#contact"
								class="bg-violet-600 text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-violet-500 transition-colors"
							>
								Contact me
							</a>
							<a
								href="https://github.com/metalogico"
								target="_blank"
								class="border border-gray-700 text-gray-300 px-5 py-2.5 rounded-md text-sm font-medium hover:border-gray-500 hover:text-white transition-colors"
							>
								GitHub
							</a>
						</div>
					</div>

					<!-- Profile Image -->
					<div class="shrink-0 avatar-wrapper">
						<div class="avatar-ring">
							<div class="avatar-inner">
								<img
									src="/avatar.png"
									alt="Michele Brandolin"
									class="w-full h-full object-cover rounded-full"
								/>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Section -->
		<section id="about" class="py-20 border-t border-gray-800/50">
			<div class="max-w-3xl mx-auto px-6">
				<h2 class="text-2xl font-bold mb-10">About me</h2>

				<div class="grid md:grid-cols-2 gap-12">
					<div class="space-y-4">
						<p class="text-gray-400 leading-relaxed">
							Web developer since 2000 with a strong passion for
							software architecture and creative problem solving.
							I specialize in building complex and scalable web
							applications.
						</p>
						<p class="text-gray-400 leading-relaxed">
							I am currently expanding my skills in mobile
							development with Flutter, always exploring new
							technologies and interesting challenges.
						</p>
						<div class="flex flex-wrap gap-2 pt-2">
							<span class="px-3 py-1 bg-gray-800 text-gray-300 rounded text-xs">Laravel</span>
							<span class="px-3 py-1 bg-gray-800 text-gray-300 rounded text-xs">PHP</span>
							<span class="px-3 py-1 bg-gray-800 text-gray-300 rounded text-xs">JavaScript</span>
							<span class="px-3 py-1 bg-gray-800 text-gray-300 rounded text-xs">Python</span>
							<span class="px-3 py-1 bg-gray-800 text-gray-300 rounded text-xs">Vue3</span>
							<span class="px-3 py-1 bg-gray-800 text-gray-300 rounded text-xs">Flutter</span>
						</div>
					</div>

					<div class="space-y-4">
						<div class="grid grid-cols-2 gap-4">
							<div class="p-5 bg-gray-800/50 rounded-lg">
								<div class="text-2xl font-bold text-violet-400 mb-1">
									25+
								</div>
								<div class="text-gray-500 text-sm">
									Years of experience
								</div>
							</div>
							<div class="p-5 bg-gray-800/50 rounded-lg">
								<div class="text-2xl font-bold text-violet-400 mb-1">
									800+
								</div>
								<div class="text-gray-500 text-sm">
									Completed projects
								</div>
							</div>
						</div>
						<div class="p-5 bg-gray-800/50 rounded-lg border-l-2 border-violet-500">
							<div class="text-lg font-semibold text-white mb-1">
								Software Architect
							</div>
							<div class="text-gray-500 text-sm">
								Currently at infoFactory SRL
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Experience Section -->
		<section id="experience" class="py-20 border-t border-gray-800/50">
			<div class="max-w-3xl mx-auto px-6">
				<h2 class="text-2xl font-bold mb-10">Experience</h2>

				<div class="timeline space-y-6">
					<div class="timeline-item fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800">
						<div class="flex items-start justify-between mb-2">
							<div>
								<h3 class="text-lg font-semibold text-white">Beliven SRL</h3>
								<p class="text-gray-400 text-sm">Software Architect, Full Stack Developer</p>
							</div>
							<span class="text-xs text-gray-500 shrink-0 mt-1">2020 &ndash; 2023</span>
						</div>
						<p class="text-xs text-gray-600 mb-3 flex items-center">
							<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>
							Udine, Italy
						</p>
						<p class="text-sm text-gray-500 leading-relaxed">
							Software architecture, database design and developer
							coaching. Development with Laravel and Node.js, with
							a focus on quality and performance.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Laravel</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">NodeJs</span>
						</div>
					</div>

					<div class="timeline-item fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800">
						<div class="flex items-start justify-between mb-2">
							<div>
								<h3 class="text-lg font-semibold text-white">SupplHi SRL</h3>
								<p class="text-gray-400 text-sm">Full Stack Developer</p>
							</div>
							<span class="text-xs text-gray-500 shrink-0 mt-1">2019 &ndash; 2020</span>
						</div>
						<p class="text-xs text-gray-600 mb-3 flex items-center">
							<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>
							Udine, Italy
						</p>
						<p class="text-sm text-gray-500 leading-relaxed">
							Vertical project for supplier management. Java
							Spring Boot backend, Angular 8 frontend, solutions
							for complex forms with JSON.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Java</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Angular</span>
						</div>
					</div>

					<div class="timeline-item fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800">
						<div class="flex items-start justify-between mb-2">
							<div>
								<h3 class="text-lg font-semibold text-white">OnlineSucces BV</h3>
								<p class="text-gray-400 text-sm">Software Architect</p>
							</div>
							<span class="text-xs text-gray-500 shrink-0 mt-1">2017 &ndash; 2018</span>
						</div>
						<p class="text-xs text-gray-600 mb-3 flex items-center">
							<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>
							Haarlem, Netherlands
						</p>
						<p class="text-sm text-gray-500 leading-relaxed">
							Big-data platform with 4 billion records. Python
							backend, high-speed APIs, load balancer and Redis
							caching.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Python</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Redis</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">ElasticSearch</span>
						</div>
					</div>

					<div class="timeline-item fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800">
						<div class="flex items-start justify-between mb-2">
							<div>
								<h3 class="text-lg font-semibold text-white">Freelance</h3>
								<p class="text-gray-400 text-sm">Interim CTO</p>
							</div>
							<span class="text-xs text-gray-500 shrink-0 mt-1">2016 &ndash; 2017</span>
						</div>
						<p class="text-xs text-gray-600 mb-3 flex items-center">
							<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>
							Amsterdam, Netherlands
						</p>
						<p class="text-sm text-gray-500 leading-relaxed">
							Strategic consulting for a European startup.
							International team of 15, scalable SOA architecture,
							high-traffic portals with millions of users and
							transactions.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Consulting</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Architecture</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Leadership</span>
						</div>
					</div>

					<div class="timeline-item fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800">
						<div class="flex items-start justify-between mb-2">
							<div>
								<h3 class="text-lg font-semibold text-white">GruppoGreenPower</h3>
								<p class="text-gray-400 text-sm">CTO, Software Architect</p>
							</div>
							<span class="text-xs text-gray-500 shrink-0 mt-1">2011 &ndash; 2013</span>
						</div>
						<p class="text-xs text-gray-600 mb-3 flex items-center">
							<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>
							Mirano, Italy
						</p>
						<p class="text-sm text-gray-500 leading-relaxed">
							Built a team from scratch, CRM with modular SOA
							architecture, appointment geolocation, multi-level
							marketing portal. Multi million software project.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">CRM</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">GMaps</span>
						</div>
					</div>

					<div class="timeline-item fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800">
						<div class="flex items-start justify-between mb-2">
							<div>
								<h3 class="text-lg font-semibold text-white">Intuito Lab</h3>
								<p class="text-gray-400 text-sm">Owner</p>
							</div>
							<span class="text-xs text-gray-500 shrink-0 mt-1">2010 &ndash; 2015</span>
						</div>
						<p class="text-xs text-gray-600 mb-3 flex items-center">
							<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>
							Gorizia, Italy
						</p>
						<p class="text-sm text-gray-500 leading-relaxed">
							Custom web apps, mobile development, geolocation.
							Clients: Allianz, Philips, Domy. Innovative projects
							such as QRWines.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Startup</span>
							<span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded font-mono">Innovation</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Section -->
		<section id="projects" class="py-20 border-t border-gray-800/50">
			<div class="max-w-3xl mx-auto px-6">
				<h2 class="text-2xl font-bold mb-10">
					Projects & Repositories
				</h2>

				<div class="grid md:grid-cols-2 gap-6 mb-12">
					<!-- GitHub Projects -->
					<div class="fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800 hover:-translate-y-0.5 transition-transform duration-200">
						<div class="flex items-center justify-between mb-4">
							<h3 class="text-lg font-semibold">GitHub Projects</h3>
							<i data-lucide="github" class="w-5 h-5 text-gray-600"></i>
						</div>
						<p class="text-sm text-gray-500 mb-5">
							Open-source packages and tools for Laravel and
							Django developers.
						</p>

						<div class="space-y-3 mb-5">
							<a
								href="https://github.com/metalogico/laravel-formello"
								target="_blank"
								class="block p-3 bg-gray-800/50 rounded hover:bg-gray-700/50 transition-colors group"
							>
								<h4 class="text-sm font-medium text-gray-300 group-hover:text-violet-400 transition-colors">
									Laravel Formello
								</h4>
								<p class="text-xs text-gray-600 mt-0.5">
									Form builder package for Laravel
								</p>
							</a>

							<a
								href="https://github.com/metalogico/laravel-mocka"
								target="_blank"
								class="block p-3 bg-gray-800/50 rounded hover:bg-gray-700/50 transition-colors group"
							>
								<h4 class="text-sm font-medium text-gray-300 group-hover:text-violet-400 transition-colors">
									Laravel Mocka
								</h4>
								<p class="text-xs text-gray-600 mt-0.5">
									API mocking tool for Laravel
								</p>
							</a>

							<a
								href="https://github.com/metalogico/django-sonar"
								target="_blank"
								class="block p-3 bg-gray-800/50 rounded hover:bg-gray-700/50 transition-colors group"
							>
								<h4 class="text-sm font-medium text-gray-300 group-hover:text-violet-400 transition-colors">
									Django Sonar
								</h4>
								<p class="text-xs text-gray-600 mt-0.5">
									Monitoring and debugging tool for Django
								</p>
							</a>
						</div>

						<a
							href="https://github.com/metalogico"
							target="_blank"
							class="text-sm text-gray-400 hover:text-violet-400 transition-colors"
						>
							View all repositories &rarr;
						</a>
					</div>

					<!-- Web Portfolio -->
					<div class="fade-in bg-gray-800/30 p-6 rounded-lg border border-gray-800 hover:-translate-y-0.5 transition-transform duration-200">
						<div class="flex items-center justify-between mb-4">
							<h3 class="text-lg font-semibold">Web Portfolio</h3>
							<i data-lucide="globe" class="w-5 h-5 text-gray-600"></i>
						</div>
						<p class="text-sm text-gray-500 mb-5">
							SaaS products and web applications built for real
							users.
						</p>

						<div class="space-y-3 mb-5">
							<a
								href="https://heresmyshelf.com"
								target="_blank"
								class="block p-3 bg-gray-800/50 rounded hover:bg-gray-700/50 transition-colors group"
							>
								<h4 class="text-sm font-medium text-gray-300 group-hover:text-violet-400 transition-colors">
									Here's My Shelf
								</h4>
								<p class="text-xs text-gray-600 mt-0.5">
									Show off your boardgames collection.
								</p>
							</a>

							<a
								href="https://useissued.com"
								target="_blank"
								class="block p-3 bg-gray-800/50 rounded hover:bg-gray-700/50 transition-colors group"
							>
								<h4 class="text-sm font-medium text-gray-300 group-hover:text-violet-400 transition-colors">
									Issued.
								</h4>
								<p class="text-xs text-gray-600 mt-0.5">
									Personal comics media-center with mobile/web
									reader.
								</p>
							</a>
						</div>
					</div>
				</div>

				<!-- Tech Stack -->
				<div>
					<h3 class="text-lg font-semibold mb-5">Primary Tech Stack</h3>
					<div class="flex flex-wrap gap-3">
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="code" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">PHP</span>
								<span class="text-xs text-gray-600 ml-1">20+ years</span>
							</div>
						</div>
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="palette" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">Laravel</span>
								<span class="text-xs text-gray-600 ml-1">Expert</span>
							</div>
						</div>
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="terminal" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">Python</span>
								<span class="text-xs text-gray-600 ml-1">6 years</span>
							</div>
						</div>
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="smartphone" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">Flutter</span>
								<span class="text-xs text-gray-600 ml-1">Learning</span>
							</div>
						</div>
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="database" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">MySQL</span>
								<span class="text-xs text-gray-600 ml-1">20+ years</span>
							</div>
						</div>
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="zap" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">Redis</span>
								<span class="text-xs text-gray-600 ml-1">Advanced</span>
							</div>
						</div>
						<div class="fade-in flex items-center gap-2 bg-gray-800/30 border border-gray-800 px-4 py-2.5 rounded-lg">
							<i data-lucide="search" class="w-4 h-4 text-gray-500"></i>
							<div>
								<span class="text-sm text-gray-300 font-mono">ElasticSearch</span>
								<span class="text-xs text-gray-600 ml-1">Advanced</span>
							</div>
						</div>
					</div>
				</div>
			</div>
